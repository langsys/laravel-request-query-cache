{
    "name": "langsys/laravel-request-query-cache",
    "description": "Per-request in-memory deduplication for Eloquent queries via firstCached() and getCached() macros.",
    "type": "library",
    "version": "1.0.0",
    "keywords": [
        "laravel",
        "eloquent",
        "query",
        "cache",
        "memoize",
        "per-request"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Langsys",
            "email": "dev@flexmarkintl.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Langsys\\RequestQueryCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Langsys\\RequestQueryCache\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Langsys\\RequestQueryCache\\RequestQueryCacheServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
